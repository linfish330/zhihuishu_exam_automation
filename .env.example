# 智慧树账号配置
ZHIHUISHU_USERNAME=YOURNAME
ZHIHUISHU_PASSWORD=YOURPASSWORD

# 视频下载器专用配置
COURSE_NAME="课程名称"
DOWNLOAD_DIR="./videos"         # 视频保存目录（相对于脚本所在目录）
QUALITY="low"                  # high=高清(原画) / low=标清(512)
CONCURRENT=3                   # 同时下载数量

# 视频转写 API 配置（用于转写生成 Markdown 知识库）
MIMO_API_KEY=YOUR_MIMO_API_KEY
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-asr

# API配置（以QWEN为例，用于考试自动答题）
QWEN_API_KEY="APIKEY"
QWEN_ENDPOINT="https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions"

# 答题模型配置
ANSWER_MODEL="qwen3.7-plus"  # 用于考试答题的模型
OCR_MODEL="qwen3.6-flash"     # 用于OCR识别的视觉模型

# 可选配置
SKIP_COMPLETED_QUESTIONS=true  # 是否跳过已完成的题目
ENABLE_REASONING=false         # 是否启用推理模式
EXAM_URL=""                    # 考试链接（如果有特定链接）
AUTOMODE=false                 # 是否开启全自动考试模式（自动登录并依次完成指定课程的所有未做考试）

# 参考资料配置（答题脚本使用）
REFERENCE_DIR="reference_materials"  # 参考资料文件夹路径，默认为 reference_materials
REFERENCE_MODE="rag"                 # 参考资料模式：rag (智能检索 top K)，full (全部导入)，none (不导入)
REFERENCE_TOP_K=3                    # 当模式为 rag 时，检索的相关文档数量